# Часовой пояс
TZ=Europe/Moscow

# SMB / сетевой диск (NAS, роутер Кинетик и т.д.)
SMB_HOST=//192.168.1.45/Transmission
SMB_USER=admin
SMB_PASSWORD=your_password

# Telegram бот (получить у @BotFather)
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ваш Telegram ID (получить у @userinfobot)
ALLOWED_USER_ID=123456789

# Как часто бот проверяет завершённые загрузки (секунды)
CHECK_INTERVAL=30
